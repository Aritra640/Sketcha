{
  "name": "ws",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run ./src/index.ts --watch",
    "build": "bun build ./src/index.ts --outdir ./build --minify",
    "start": "bun build ./src/index.ts --outdir ./build  && bun run ./build/index.js --watch",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit"
  }
}
