{
  "name": "@repo/db",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "prisma": "^7.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run dev:compile & bun run dev:run",
    "dev:compile": "tsc --watch",
    "dev:run": "bun --watch ./dist/src/index.js",
    "build": "tsc",
    "seed:DB": "bunx --bun prisma db seed",
    "delete:allguests": "bun run ./scripts/deleteAllGuests.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
